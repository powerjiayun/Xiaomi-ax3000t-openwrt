# 1. 硬件锁定 (小米 AX3000T V1)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_xiaomi_mi-router-ax3000t=y

# 2. 闭源驱动专属无线面板 (硬件加速已交由底层原生接管)
CONFIG_PACKAGE_luci-app-mtwifi-cfg=y

# 打开zram
CONFIG_PACKAGE_zram-swap=y

# DNS 完整版（nikki 依赖，替换精简版 dnsmasq）
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y

# 网络插件
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y

# 基础工具
CONFIG_PACKAGE_curl=y

# 系统工具 (ttyd 网页终端、自动重启、内存清理)
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-ramfree=y

# 界面主题与语言包底座 (防止极简编译丢失中文)
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# HomeProxy 代理插件（上游自带，无需额外拉取仓库）
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
